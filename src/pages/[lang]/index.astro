---
import Layout from '../../layouts/Layout.astro';
import { getTranslations, translations, defaultLang, type Lang } from '../../i18n';

// Generate a page for each supported language
export function getStaticPaths() {
    return Object.keys(translations).map((lang) => ({ params: { lang } }));
}

// Current language from URL or default
const { lang = defaultLang } = Astro.params as { lang: Lang };

// Load translations for the current language
const { site, hero } = getTranslations(lang);

// Example variables for interpolation
const visitorName = 'Astro';
const foo = 'i18n';
const bar = 'TypeScript';
---

<Layout lang={lang}>
    <main class="page">
        <section class="hero">
            <p class="eyebrow">{site.tagline}</p>
            <h1>{site.brand}</h1>
            <h2>{hero.title}</h2>

            <div class="examples">
                <p>{hero.description({ name: visitorName })}</p>
                <p>{hero.example({ foo: foo, bar: bar })}</p>
            </div>

            <a href={`/${lang}/about/`}>About</a>
        </section>
    </main>
</Layout>

<style>
    .page {
        display: grid;
        min-height: 72vh;
        place-items: center;
        padding: 2.5rem 1.5rem;
    }

    .hero {
        width: min(100%, 40rem);
    }

    .eyebrow {
        color: #5f6f52;
        font-size: 0.875rem;
        font-weight: 700;
        margin: 0 0 0.75rem;
        text-transform: uppercase;
    }

    a {
        color: #394150;
        display: inline-block;
        font-weight: 700;
        margin-top: 2rem;
        text-decoration-color: #9db675;
        text-underline-offset: 0.25rem;
    }

    h1 {
        color: #1d2433;
        font-size: 3rem;
        line-height: 1;
        margin: 0;
    }

    h2 {
        color: #394150;
        font-size: 1.5rem;
        font-weight: 500;
        margin: 1rem 0 2rem;
    }

    .examples {
        border-left: 3px solid #9db675;
        color: #4b5563;
        display: grid;
        gap: 0.75rem;
        padding-left: 1rem;
    }

    .examples p {
        margin: 0;
    }
</style>
